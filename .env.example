# Copy to .env and fill in only the integrations you will use. Deterministic Demo
# mode and the test suite need no external credentials. The simplest free Live setup uses
# Gemini for structured model calls and Tavily for web search.

# evidence-audit Studio and durable local audit state
STUDIO_PORT=4500
AUDIT_DB_PATH=data/audits.db

# recommended zero-payment Live model
# GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# recommended zero-payment Live search; Tavily offers a limited free developer allowance
# TAVILY_API_KEY=

# optional alternative search provider; when configured, Brave is preferred for search
# BRAVE_SEARCH_API_KEY=

# optional paid Gemini Google Search grounding instead of Tavily or Brave
# GEMINI_SEARCH_GROUNDING=false

# optional Claude fallback when GEMINI_API_KEY is not configured; the path is
# auto-detected from PATH if unset
# CLAUDE_CODE_PATH=

# optional Live workflow timeouts in milliseconds
# AUDIT_MAPPING_TIMEOUT_MS=60000
# AUDIT_TIMEOUT_MS=300000

# optional estimated cost rates; set all three together or leave all three unset
# MODEL_CALL_COST_USD=
# SEARCH_CALL_COST_USD=
# PAGE_FETCH_COST_USD=

# mock vendor server
VENDOR_PORT=4100
VENDOR_DB=data/vendors.db
# where the agent and reset script look for the vendors
VENDOR_URL=http://127.0.0.1:4100

# ledger
LEDGER_PATH=data/ledger.db
SAGA_ID=trip

# ledger viewer
VIEWER_PORT=4200

# demo crash harness: "<actionType>:<event>", e.g. hotel.book:CALLED
# CRASH_AFTER=

# Google Calendar (the one real integration)
# OAuth desktop client from Google Cloud console, Calendar API enabled
# GCAL_CLIENT_ID=
# GCAL_CLIENT_SECRET=
GCAL_AUTH_PORT=4300
GCAL_CALENDAR_ID=primary
