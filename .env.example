# Copy to .env and fill in. Everything has a sane default except the Google
# OAuth client, which is only needed for the real calendar leg of the demo.

# mock vendor server
VENDOR_PORT=4100
VENDOR_DB=data/vendors.db
# where the agent and reset script look for the vendors
VENDOR_URL=http://127.0.0.1:4100

# ledger
LEDGER_PATH=data/ledger.db
SAGA_ID=trip

# ledger viewer
VIEWER_PORT=4200

# demo crash harness: "<actionType>:<event>", e.g. hotel.book:CALLED
# CRASH_AFTER=

# path to the local claude CLI the agent rides; auto-detected from PATH if unset
# CLAUDE_CODE_PATH=

# Google Calendar (the one real integration)
# OAuth desktop client from Google Cloud console, Calendar API enabled
# GCAL_CLIENT_ID=
# GCAL_CLIENT_SECRET=
GCAL_AUTH_PORT=4300
GCAL_CALENDAR_ID=primary
